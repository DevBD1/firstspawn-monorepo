{
  "name": "firstspawn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --if-present dev",
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint -- --fix",
    "test": "pnpm -r --if-present test",
    "clean": "pnpm -r --if-present clean && rm -rf node_modules",
    "format": "pnpm exec prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,json,yml,yaml,css,sql}\"",
    "format:check": "pnpm exec prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,md,json,yml,yaml,css,sql}\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.9.0"
  }
}
