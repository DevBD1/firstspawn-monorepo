    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "react": "19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@firstspawn/typescript-config": "workspace:*",
    "@types/react": "^19",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8.57.0"
  }
