{
  "name": "@firstspawn/ui",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./branding/tokens": {
      "types": "./src/branding/tokens.ts",
      "default": "./src/branding/tokens.ts"
    },
    "./styles/brand.css": "./src/styles/brand.css"
  },
  "files": [
    "src"
  ],
