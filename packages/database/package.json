    "clean": "rm -rf migrations/*.sql migrations/meta"
  },
  "devDependencies": {
    "@firstspawn/typescript-config": "workspace:*",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.6",
    "typescript": "^5"
  }
}
