# Code Owners
# Lines starting with # are comments
# Each line is a file pattern followed by one or more owners
# Owners will be requested for review when someone opens a PR that modifies files matching the pattern
# The last matching pattern takes precedence

# Global fallback - if no other pattern matches
* @firstspawn/maintainers

# Package configurations
/packages/ @firstspawn/maintainers
/pnpm-workspace.yaml @firstspawn/maintainers
/package.json @firstspawn/maintainers

# Documentation
*.md @firstspawn/docs-team
/docs/ @firstspawn/docs-team

# Web app
/apps/web/ @firstspawn/web-team
/apps/web/src/app/ @firstspawn/web-team
/apps/web/src/components/ @firstspawn/web-team

# API
/apps/api/ @firstspawn/api-team
/packages/database/ @firstspawn/api-team

# Infrastructure and DevOps
/infrastructure/ @firstspawn/devops
/docker-compose.yml @firstspawn/devops
/.github/ @firstspawn/devops
/.github/workflows/ @firstspawn/devops
