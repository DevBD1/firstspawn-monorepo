# ==================================
# FirstSpawn — Root Environment Variables
# ==================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────
# Web App (Next.js)
# ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# API base URL mode:
# - Direct API dev (pnpm api dev):        http://localhost:8000/api/v1
# - Full Docker + Nginx host routing:     http://api.localhost/api/v1
API_BASE_URL=http://api.localhost/api/v1
# Used by web server actions/proxy when API is behind Nginx Basic Auth.
# Keep same values as NGINX_AUTH_USER / NGINX_AUTH_PASS.
API_BASIC_AUTH_USER=firstspawn_admin
API_BASIC_AUTH_PASS="fs_admin_password"

# Beta Protection Toggle
# Prefer the server-only toggle for proxy route gating.
LOCK_BETA_ROUTES=false
# Backward-compatible fallback for older builds.
NEXT_PUBLIC_LOCK_BETA_ROUTES=false

# ──────────────────────────────────
# DB (PostgreSQL)
# ──────────────────────────────────
DB_HOST=localhost
DB_USER=firstspawn_admin
DB_PASSWORD="fs_admin_password"
DB_NAME=firstspawn_development # firstspawn_development | firstspawn_production

# ──────────────────────────────────
# Dozzle
# ──────────────────────────────────
DOZZLE_USERNAME=firstspawn_admin
DOZZLE_PASSWORD="fs_admin_password"

# ──────────────────────────────────
# Nginx Basic Auth (api.localhost, logs.localhost)
# ──────────────────────────────────
NGINX_AUTH_USER=firstspawn_admin
NGINX_AUTH_PASS="fs_admin_password"

# ──────────────────────────────────
# API (Fastify)
# ──────────────────────────────────
API_ENV=development # development | production
API_HOST=0.0.0.0
API_PORT=8000
# Keep placeholder form so special chars in DB_PASSWORD are URL-encoded safely.
API_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}
API_REDIS_URL=redis://localhost:6379/0
API_JWT_SECRET=change_me_to_a_long_random_secret
API_TOKEN_HASH_SECRET=change_me_to_a_long_random_secret_for_hmac
API_JWT_ISSUER=firstspawn-api
API_ACCESS_TOKEN_EXPIRE_MINUTES=15
API_REFRESH_TOKEN_EXPIRE_DAYS=30
API_ADMIN_EMAIL_ALLOWLIST=admin@firstspawn.com
API_COLLECTOR_KEY=change_me_collector_key

# ──────────────────────────────────
# Collector (apps/collector)
# ──────────────────────────────────
# Mode:
# - Docker collector container -> http://api:8000/api/v1
# - Local collector process    -> http://localhost:8000/api/v1
COLLECTOR_API_BASE_URL=http://api:8000/api/v1
COLLECTOR_INSTANCE_ID=collector-local-1
# Fixed fleet probe cadence. Must stay at 600 seconds for ten-minute UTC slots.
COLLECTOR_PROBE_INTERVAL_SECONDS=600
COLLECTOR_CONCURRENCY=50
COLLECTOR_TARGET_PAGE_SIZE=500
# Timeout for collector to wait for API responses, in milliseconds. Adjust based on your API's typical response times and network conditions.
COLLECTOR_PROBE_TIMEOUT_MS=5000
# Host and port for collector to listen on when running as a server (optional, used for health checks or if collector exposes its own API).
COLLECTOR_HOST=0.0.0.0
COLLECTOR_PORT=8081

# ──────────────────────────────────
# Scheduler (supercronic)
# UTC cron expressions and probe-history tiers
# ──────────────────────────────────
# Refreshes closed UTC hours and days for chart queries.
SCHEDULE_PROBE_ROLLUPS="*/10 * * * *"
ROLLUP_LAG_MINUTES=10
ROLLUP_LOOKBACK_HOURS=3
# Raw -> hourly -> daily retention windows.
RETENTION_DAYS=2
HOURLY_RETENTION_DAYS=90
DAILY_RETENTION_DAYS=730
# Runs every day at 2:00 AM UTC to evaluate explicit archive evidence.
SCHEDULE_ARCHIVE_INACTIVE="0 2 * * *"
# Finalizes the full retention window before safely purging old history.
SCHEDULE_ROLLUP_RETENTION="30 2 * * *"
# Runs every day at 3:00 AM UTC to permanently delete users who have been archived for over 30 days.
SCHEDULE_PURGE_DELETED_USERS="0 3 * * *"

# ──────────────────────────────────
# Mail (SMTP)
# ──────────────────────────────────
MAIL_USERNAME=admin@firstspawn.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM=admin@firstspawn.com
MAIL_PORT=587
MAIL_SERVER=mail.firstspawn.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
FRONTEND_URL=http://localhost:3000

# Optional docker-mailserver stack.
# Compose profiles:
# - backend: postgres, redis, api, nginx
# - frontend: reserved for future Next.js web and admin containers
# - mail: mailserver
# - devops: pgadmin, dozzle
# - workers: collector, scheduler
#
# Services are behind profiles, so plain `docker compose up` does not start them.
# On the mail VPS, run:
#   docker compose --profile mail up -d mailserver
MAILSERVER_HOSTNAME=mail.firstspawn.com
MAILSERVER_POSTMASTER_ADDRESS=postmaster@firstspawn.com
MAILSERVER_ENABLE_RSPAMD=1
MAILSERVER_ENABLE_CLAMAV=0
MAILSERVER_ENABLE_FAIL2BAN=1
MAILSERVER_SPOOF_PROTECTION=1
MAILSERVER_SSL_TYPE=
MAILSERVER_SMTP_PORT=25
MAILSERVER_SUBMISSION_PORT=587
MAILSERVER_SMTPS_PORT=465
MAILSERVER_IMAPS_PORT=993

# ──────────────────────────────────
# AI Captcha (optional — degrades gracefully)
# ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# ──────────────────────────────────
# Newsletter (Resend)
# ──────────────────────────────────
RESEND_API_KEY=your_resend_api_key
JWT_SECRET=your_jwt_secret_for_newsletter_confirmation
RESEND_AUDIENCE_ID=your_resend_audience_id

# ──────────────────────────────────
# Cloudflare Turnstile
# ──────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
