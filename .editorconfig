# EditorConfig helps maintain consistent coding styles across different editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Python files
[*.{py,pyi}]
indent_size = 4
max_line_length = 100

# JSON files (package.json, tsconfig.json, etc.)
[*.{json,yml,yaml}]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

# Windows batch files
[*.{cmd,bat}]
end_of_line = crlf

# Database migrations and generated SQL jobs (keep as-is)
[packages/database/{migrations,jobs}/**/*]
max_line_length = off
