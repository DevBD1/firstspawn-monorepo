{
  "name": "@firstspawn/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "corepack pnpm --filter @firstspawn/database build && tsx watch src/index.ts",
    "build": "corepack pnpm --filter @firstspawn/database build && tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "lint": "eslint .",
    "typecheck": "corepack pnpm --filter @firstspawn/database build && tsc --noEmit",
    "test": "corepack pnpm --filter @firstspawn/database build && corepack pnpm exec vitest run",
    "clean": "rm -rf dist coverage .vitest",
    "migrate": "pnpm --dir ../../packages/database run migrate",
    "migrate:generate": "pnpm --dir ../../packages/database run generate"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@firstspawn/database": "workspace:*",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^5.1.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@firstspawn/typescript-config": "workspace:*",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.2",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
