set -eu

echo "🔍 Running pre-commit checks..."

# Run lint-staged
pnpm exec lint-staged --concurrent false

# Check for potential secrets in added lines only.
SENSITIVE_NAME_PATTERN="API_KEY|SECRET|PASSWORD|TOKEN|PRIVATE_KEY|DATABASE_URL"
if git diff --cached --no-color --unified=0 | grep -E "^\+[[:space:]]*[A-Za-z_][A-Za-z0-9_ -]*($SENSITIVE_NAME_PATTERN)[A-Z0-9_ -]*[=:]" >/dev/null 2>&1; then
  echo "⚠️  Warning: Potential secrets found in staged added lines."
  echo "Review staged diff before pushing."

  if [ "${HUSKY_BLOCK_SECRETS:-1}" = "1" ]; then
    echo "Strict mode on. Blocking commit."
    echo "Use HUSKY_BLOCK_SECRETS=0 only after manually verifying the staged diff."
    exit 1
  else
    echo "Continuing because HUSKY_BLOCK_SECRETS=0."
  fi
fi

echo "✅ Pre-commit checks passed!"
