. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged
npx lint-staged

# Check for secrets (basic check)
if git diff --cached --name-only | xargs grep -l "API_KEY\|SECRET\|PASSWORD\|TOKEN" 2>/dev/null | grep -v "\.example\|\.md\|husky\|package.json\|pyproject.toml"; then
  echo "⚠️  Warning: Potential secrets detected in staged files. Please review."
  echo "If these are example values or documentation, you can continue."
  read -p "Continue anyway? (y/N) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

echo "✅ Pre-commit checks passed!"
