{
  "apps/api/**/*.{ts,tsx,js,jsx}": [
    "prettier --write",
    "pnpm exec eslint --fix --config apps/api/eslint.config.mjs"
  ],
  "apps/collector/**/*.{ts,tsx,js,jsx}": [
    "prettier --write",
    "pnpm exec eslint --fix --config apps/collector/eslint.config.mjs"
  ],
  "apps/web/**/*.{ts,tsx,js,jsx}": [
    "prettier --write",
    "pnpm exec eslint --fix --config apps/web/eslint.config.mjs"
  ],
  "packages/ui/**/*.{ts,tsx,js,jsx}": [
    "prettier --write",
    "pnpm exec eslint --fix --config packages/ui/eslint.config.mjs"
  ],
  "packages/database/**/*.{ts,tsx,js,jsx,mjs,cjs,json}": ["prettier --write"],
  "*.json": ["prettier --write"],
  "*.md": ["prettier --write"],
  "*.yml": ["prettier --write"],
  "*.yaml": ["prettier --write"],
  "*.css": ["prettier --write"]
}
